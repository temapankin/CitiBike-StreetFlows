# Copy to .env and fill in values.
# DB is a per-project Postgres cluster managed by this repo (no system Postgres needed).
PGHOST=localhost
PGPORT=5455
PGDATABASE=citibike
PGUSER=citibike
PGPASSWORD=citibike

# Where the per-project Postgres cluster stores its data files
PGDATA=.pgdata

# osm2pgrouting mapconfig (shipped with osm2pgrouting in the conda env)
OSM2PGROUTING_MAPCONFIG=mapconfig_for_cars.xml
